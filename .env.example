# Copy to Hostinger → Environment variables (and/or local `.env.local`).
# NEXT_PUBLIC_* values are inlined at build time — set them before deploy, then redeploy.

# Public URL of this Next.js storefront (no trailing slash).
# Hostinger preview example:
# NEXT_PUBLIC_SITE_URL=https://darkslategrey-gazelle-896289.hostingersite.com
# After you map your domain:
# NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com
NEXT_PUBLIC_SITE_URL=https://darkslategrey-gazelle-896289.hostingersite.com

# Laravel API base URL (must end with /api). Not localhost in production.
NEXT_PUBLIC_API_URL=https://api.darkslategrey-gazelle-896289.hostingersite.com/api

# Optional: absolute URL to logo if your main domain SSL is not ready yet.
# NEXT_PUBLIC_LOGO_URL=https://your-cdn.example.com/sjbw-logo.png
