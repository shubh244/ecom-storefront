# Copy to Laravel root as .env on Hostinger (PHP site only)

APP_NAME="Shreejee API"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.YOUR-PHP-DOMAIN.com

FRONTEND_URL=https://YOUR-STOREFRONT-DOMAIN.com
CORS_ALLOWED_ORIGINS=https://YOUR-STOREFRONT-DOMAIN.com

APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u274811071_shreejee
DB_USERNAME=u274811071_shreejee
DB_PASSWORD=YOUR_DB_PASSWORD

SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file

LOG_CHANNEL=stack
LOG_LEVEL=error
